#!/bin/sh
# Local commit author guard — not run until you install it:
#   cp .githooks/pre-commit.example .githooks/pre-commit
#   git config core.hooksPath .githooks
#
# Set identity via env (keeps emails out of this file) or edit the defaults below.
REQUIRED_NAME="${ENIGMA_COMMIT_AUTHOR_NAME:-Your GitHub Username}"
REQUIRED_EMAIL="${ENIGMA_COMMIT_AUTHOR_EMAIL:-you@example.com}"
BLOCKED_EMAILS="${ENIGMA_BLOCKED_EMAILS:-}"

NAME=$(git config user.name)
EMAIL=$(git config user.email)
if [ -n "$GIT_AUTHOR_NAME" ]; then NAME="$GIT_AUTHOR_NAME"; fi
if [ -n "$GIT_AUTHOR_EMAIL" ]; then EMAIL="$GIT_AUTHOR_EMAIL"; fi

EMAIL_LC=$(printf '%s' "$EMAIL" | tr 'A-Z' 'a-z')
REQUIRED_LC=$(printf '%s' "$REQUIRED_EMAIL" | tr 'A-Z' 'a-z')

for blocked in $BLOCKED_EMAILS; do
  blocked_lc=$(printf '%s' "$blocked" | tr 'A-Z' 'a-z')
  if [ "$EMAIL_LC" = "$blocked_lc" ]; then
    echo ""
    echo "BLOCKED: commit author email is $EMAIL."
    echo "Only $REQUIRED_NAME <$REQUIRED_EMAIL> may commit to this repo."
    echo ""
    exit 1
  fi
done

if [ "$NAME" != "$REQUIRED_NAME" ] || [ "$EMAIL_LC" != "$REQUIRED_LC" ]; then
  echo ""
  echo "BLOCKED: commit author must be $REQUIRED_NAME <$REQUIRED_EMAIL>"
  echo "Current identity: $NAME <$EMAIL>"
  echo ""
  exit 1
fi

exit 0
